{
  "manifest_version": 3,
  "name": "CNPJ/CPF - Remover Pontuação",
  "description": "Selecione um CNPJ ou CPF e copie somente os números, sem pontuação.",
  "version": "1.0",
  "permissions": ["contextMenus", "clipboardWrite", "scripting", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CNPJ/CPF Limpo"
  }
}
